import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns
from sklearn.preprocessing import StandardScaler, LabelEncoder
from sklearn.cluster import KMeans

# ==========================================
# STEP 1: LOAD AND PROCESS DATA
# ==========================================
# Reading input dataset
input_file = 'tourism_dataset.csv'
df = pd.read_csv(input_file)

# Create a copy for processing
df_processed = df.copy()

# Convert potential non-numeric entries in 'Visitors', 'Rating', 'Revenue' to numeric, coercing errors to NaN
for col in ['Visitors', 'Rating', 'Revenue']:
    df_processed[col] = pd.to_numeric(df_processed[col], errors='coerce')

# Drop rows where 'Visitors', 'Rating', or 'Revenue' became NaN after coercion
df_processed.dropna(subset=['Visitors', 'Rating', 'Revenue'], inplace=True)

# Preprocessing & Label Encoding
le_country = LabelEncoder()
le_category = LabelEncoder()
le_accom = LabelEncoder()

df_processed['Country_Encoded'] = le_country.fit_transform(df_processed['Country'])
df_processed['Category_Encoded'] = le_category.fit_transform(df_processed['Category'])
df_processed['Accommodation_Encoded'] = le_accom.fit_transform(df_processed['Accommodation_Available'])

# Standardizing features and running K-Means Clustering
features = ['Visitors', 'Rating', 'Revenue', 'Category_Encoded', 'Accommodation_Encoded']
X_scaled = StandardScaler().fit_transform(df_processed[features])

kmeans = KMeans(n_clusters=2, random_state=42, n_init=10)
df_processed['Cluster'] = kmeans.fit_predict(X_scaled)
df_processed['Cluster_Name'] = df_processed['Cluster'].apply(lambda x: f"Cluster {x}")

# ==========================================
# STEP 2: GENERATE VISUALIZATIONS
# ==========================================

# 1. Scatter Plot: Visitors vs Revenue segmented by Clusters
fig1, ax1 = plt.subplots(figsize=(8, 5))
sns.scatterplot(
    data=df_processed, 
    x='Visitors', 
    y='Revenue', 
    hue='Cluster_Name', 
    style='Category', 
    s=200, 
    palette='Set1',
    ax=ax1
)
ax1.set_title('Destination Segmentation: Visitors vs Revenue')
ax1.set_xlabel('Number of Visitors')
ax1.set_ylabel('Revenue (USD)')
ax1.grid(True, linestyle='--', alpha=0.5)
plt.tight_layout()
plt.savefig('visitors_vs_revenue.png')
plt.close()


# 2. Sorted Bar Chart: Total Revenue by Country
revenue_by_country = df_processed.groupby('Country')['Revenue'].sum().reset_index().sort_values(by='Revenue', ascending=False)

fig2, ax2 = plt.subplots(figsize=(6, 4))
sns.barplot(
    data=revenue_by_country, 
    x='Country', 
    y='Revenue', 
    hue='Country',  # Assign x variable to hue
    palette='Blues_r',
    legend=False, # Set legend=False
    ax=ax2
)
ax2.set_title('Total Revenue by Country (Sorted)')
ax2.set_xlabel('Country')
ax2.set_ylabel('Total Revenue (USD)')
ax2.grid(axis='y', linestyle='--', alpha=0.5)
plt.tight_layout()
plt.savefig('revenue_by_country.png')
plt.close()


# 3. Sorted Bar Chart: Total Visitors by Destination Category
visitors_by_category = df_processed.groupby('Category')['Visitors'].sum().reset_index().sort_values(by='Visitors', ascending=False)

fig3, ax3 = plt.subplots(figsize=(6, 4))
sns.barplot(
    data=visitors_by_category, 
    x='Category', 
    y='Visitors', 
    hue='Category', # Assign x variable to hue
    palette='Oranges_r',
    legend=False, # Set legend=False
    ax=ax3
)
ax3.set_title('Total Visitors by Category (Sorted)')
ax3.set_xlabel('Category')
ax3.set_ylabel('Total Visitors')
ax3.grid(axis='y', linestyle='--', alpha=0.5)
plt.tight_layout()
plt.savefig('visitors_by_category.png')
plt.close()

print("All charts generated and saved successfully.")
